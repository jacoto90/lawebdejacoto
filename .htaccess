# Security baseline
Options -Indexes

# Disable server signature
ServerSignature Off

# Block hidden files and VCS
<FilesMatch "(^\.|\.git|\.svn|\.hg)">
    Require all denied
</FilesMatch>

# Block sensitive config and backup files
<FilesMatch "(composer\.(json|lock)|\.env|\.ini|\.log|\.sql|\.bak|\.old|\.swp)$">
    Require all denied
</FilesMatch>

# Prevent direct access to internal docs/data text
<FilesMatch "^(infoCv\.txt|inodos\.txt)$">
    Require all denied
</FilesMatch>

# Basic hardening headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Disable TRACE/TRACK
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK) [NC]
    RewriteRule .* - [F,L]
</IfModule>
